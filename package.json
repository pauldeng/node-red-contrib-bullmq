{
  "name": "node-red-contrib-bull",
  "version": "0.0.7",
  "description": "A powerful job queue nodes for Node-RED",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:unit": "node --test test/*.test.js",
    "test:integration": "BULLMQ_INTEGRATION=1 node --test test/integration-standalone.test.js",
    "test:deployments": "node scripts/run-deployment-tests.js",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "bullmq": "5.78.0",
    "ioredis": "5.10.1"
  },
  "license": "MIT",
  "keywords": [
    "node-red",
    "job",
    "queue",
    "bull"
  ],
  "node-red": {
    "version": ">=4.1.0 <5",
    "nodes": {
      "bull-queue": "bull-queue.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pauldeng/node-red-contrib-bull"
  },
  "author": {
    "name": "Paul Deng",
    "email": "dengpeng.cn@gmail.com"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "mocha": "11.7.6",
    "node-red": "4.1.11",
    "node-red-node-test-helper": "^0.3.6",
    "prettier": "3.8.3",
    "sinon": "22.0.0"
  }
}
